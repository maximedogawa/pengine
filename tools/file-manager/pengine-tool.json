{
  "id": "pengine/file-manager",
  "name": "File Manager",
  "version": "0.1.0",
  "description": "Filesystem MCP in a container. Add folders in MCP Tools; each mounts at /app/<folder-name>. Install works before any folder is set.",
  "license": "Apache-2.0",
  "limits": { "cpus": "0.5", "memory": "256m", "timeout_secs": 30 },
  "container_read_only_rootfs": false,
  "mount_workspace": true,
  "mount_read_only": true,
  "append_workspace_roots": true,
  "direct_return": true,
  "upstream_mcp_npm": {
    "package": "@modelcontextprotocol/server-filesystem",
    "version": "2026.1.14"
  },
  "mcp_server_cmd": []
}
